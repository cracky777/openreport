# Open Report Configuration
NODE_ENV=production
PORT=3001

# Session secret — generate with: openssl rand -hex 32
# Required in production; startup refuses known sample values and secrets < 16 chars.
SESSION_SECRET=change-me-to-a-random-string

# Secret for in-process internal (loopback) tokens — REQUIRED, MUST differ from
# SESSION_SECRET. The server refuses to start without it. Generate: openssl rand -hex 32
INTERNAL_TOKEN_SECRET=change-me-to-a-different-random-string

# Production CORS allow-list (comma-separated). If unset in production,
# cross-origin requests are blocked (the bundled client is same-origin).
# CORS_ORIGIN=https://your-domain.example

# Encryption key for datasource credentials at rest (AES-256-GCM). 32 bytes as
# 64 hex chars. REQUIRED once any datasource with a secret exists; the server
# refuses to start without it and migrates existing plaintext rows on boot.
# Generate with: openssl rand -hex 32
DATASOURCE_ENC_KEY=change-me-64-hex-chars-0000000000000000000000000000000000000000

# HLL (approximate COUNT DISTINCT) rollup acceleration via the DuckDB
# DataSketches extension. Default: ON, except on Windows where the community
# binary can crash the process natively. Set to 1 to force on, 0 to force off.
# ROLLUP_HLL_ENABLED=1
