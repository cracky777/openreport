{
  "id": "color-grid",
  "name": "Color Grid",
  "version": "1.0.0",
  "author": "Open Report",
  "description": "Demo visual: renders one coloured square per row, sized by the selected measure. Replace the body of visual.js with your own drawing code.",

  "dataSchema": {
    "dimensions": [
      { "role": "category", "min": 1, "max": 1, "label": "Category" }
    ],
    "measures": [
      { "role": "value", "min": 1, "max": 1, "label": "Value" }
    ]
  },

  "configSchema": [
    { "key": "tileColor",  "type": "color",   "label": "Tile color",  "default": "#7c3aed" },
    { "key": "showValues", "type": "boolean", "label": "Show values", "default": true },
    { "key": "labelSize",  "type": "number",  "label": "Label size",  "min": 8, "max": 24, "step": 1, "default": 12 }
  ]
}
